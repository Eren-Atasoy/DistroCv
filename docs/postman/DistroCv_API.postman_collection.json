        {
          "name": "Google OAuth Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"GOOGLE_ID_TOKEN_BURAYA\",\n  \"preferredLanguage\": \"tr\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google"]
            },
            "description": "Gerçek Google idToken gerektirir. Google OAuth consent screen'den alınan token'ı yapıştır. Lokal test için Google Cloud Console'dan test token alabilirsin."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Google idToken olmadan 400 dönmesi beklenir",
                  "pm.test('✅ Google OAuth — token doğrulama çalışıyor', () => {",
                  "    if (pm.request.body.raw.includes('GOOGLE_ID_TOKEN_BURAYA')) {",
                  "        // Placeholder token ile 400/500 beklenir",
                  "        pm.expect(pm.response.code).to.be.oneOf([400, 500]);",
                  "    } else {",
                  "        // Gerçek token ile 200 beklenir",
                  "        pm.expect(pm.response.code).to.eql(200);",
                  "        const res = pm.response.json();",
                  "        pm.expect(res).to.have.property('accessToken');",
                  "        pm.environment.set('accessToken', res.accessToken);",
                  "        pm.environment.set('refreshToken', res.refreshToken);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
