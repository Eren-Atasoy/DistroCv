        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123!@\",\n  \"fullName\": \"Test Kullanıcı\",\n  \"preferredLanguage\": \"tr\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.environment.set('accessToken', res.accessToken);",
                  "    pm.environment.set('refreshToken', res.refreshToken);",
                  "    pm.environment.set('userId', res.user.id);",
                  "    pm.test('✅ Register başarılı', () => pm.expect(res.accessToken).to.be.a('string'));",
                  "    pm.test('✅ User objesi döndü', () => pm.expect(res.user.email).to.eql('test@example.com'));",
                  "} else {",
                  "    pm.test('❌ Register başarısız: ' + pm.response.code, () => pm.expect.fail(pm.response.text()));",
                  "}"
                ]
              }
            }
          ]
        },
