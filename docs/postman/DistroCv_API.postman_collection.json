          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('✅ Şifre değiştirildi', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});",
                  "",
                  "// Şifre değiştikten sonra eski şifreyi geri al (sonraki testler bozulmasın)",
                  "if (pm.response.code === 200 || pm.response.code === 204) {",
                  "    const revertBody = JSON.stringify({ oldPassword: 'NewTest456!@', newPassword: 'Test123!@' });",
                  "    pm.sendRequest({",
                  "        url: pm.environment.get('baseUrl') + '/auth/change-password',",
                  "        method: 'POST',",
                  "        header: {",
                  "            'Content-Type': 'application/json',",
                  "            'Authorization': 'Bearer ' + pm.environment.get('accessToken')",
                  "        },",
                  "        body: { mode: 'raw', raw: revertBody }",
                  "    }, (err, res) => {",
                  "        console.log('Şifre geri alındı:', res.code);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
